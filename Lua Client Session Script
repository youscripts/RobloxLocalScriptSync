        leaveBtn.TextScaled = true
        leaveBtn.Font = Enum.Font.SourceSansBold
        leaveBtn.Parent = sessionFrame
        leaveBtn.MouseButton1Click:Connect(function()
            sendToServer({ type = "leave" })
            sessionFrame.Visible = false
            sessionVisible = false
            showRestoreButton()
        end)
    end

    return sessionFrame
end

-- ==================== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ====================

-- Функция для перетаскивания
function makeDraggable(frame)
    local dragging = false
    local dragStartX, dragStartY
    local startPosX, startPosY

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStartX = input.Position.X
            dragStartY = input.Position.Y
            startPosX = frame.Position.X.Offset
            startPosY = frame.Position.Y.Offset
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    frame.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local deltaX = input.Position.X - dragStartX
            local deltaY = input.Position.Y - dragStartY
            frame.Position = UDim2.new(0, startPosX + deltaX, 0, startPosY + deltaY)
        end
    end)
end

-- Кнопка восстановления (если окно скрыто)
local restoreBtn = nil

function showRestoreButton()
    if restoreBtn then return end
    restoreBtn = Instance.new("TextButton")
    restoreBtn.Size = UDim2.new(0, 40, 0, 40)
    restoreBtn.Position = UDim2.new(0.02, 0, 0.02, 0)
    restoreBtn.BackgroundColor3 = Color3.new(0.2, 0.8, 0.2)
    restoreBtn.Text = "+"
    restoreBtn.TextColor3 = Color3.new(1, 1, 1)
    restoreBtn.TextScaled = true
    restoreBtn.Font = Enum.Font.SourceSansBold
    restoreBtn.Parent = gui
    makeDraggable(restoreBtn)
    restoreBtn.MouseButton1Click:Connect(function()
        -- Восстанавливаем то окно, которое было скрыто
        if sessionFrame and not sessionFrame.Visible then
            sessionFrame.Visible = true
            sessionVisible = true
        elseif mainFrame and not mainFrame.Visible then
            mainFrame.Visible = true
            mainVisible = true
        end
        restoreBtn:Destroy()
        restoreBtn = nil
    end)
end

function showMainWindow()
    if not mainFrame then
        createMainWindow()
    else
        mainFrame.Visible = true
        mainVisible = true
    end
    if restoreBtn then
        restoreBtn:Destroy()
        restoreBtn = nil
    end
end

function showSessionWindow()
    if mainFrame then
        mainFrame.Visible = false
        mainVisible = false
    end
    if not sessionFrame then
        createSessionWindow()
    else
        sessionFrame.Visible = true
        sessionVisible = true
    end
    if restoreBtn then
        restoreBtn:Destroy()
        restoreBtn = nil
    end
end

function closeSessionWindow()
    if sessionFrame then
        sessionFrame:Destroy()
        sessionFrame = nil
    end
    sessionVisible = false
end

function addOutput(message)
    if not sessionFrame or not outputLabel then return end
    local current = outputLabel.Text
    if #current > 0 then
        current = current .. "\n"
    end
    current = current .. message
    outputLabel.Text = current
    if outputFrame then
        outputFrame.CanvasSize = UDim2.new(0, 0, 0, outputLabel.TextBounds.Y + 10)
        outputFrame.CanvasPosition = Vector2.new(0, outputFrame.CanvasSize.Y.Offset)
    end
end

function executeScript(script)
    local originalPrint = _G.print
    _G.print = function(...)
        local args = {...}
        local str = ""
        for i, v in ipairs(args) do
            str = str .. tostring(v)
            if i < #args then str = str .. " " end
        end
        sendToServer({ type = "output", message = str })
    end
    local success, err = pcall(function()
        loadstring(script)()
    end)
    _G.print = originalPrint
    if not success then
        sendToServer({ type = "output", message = "Ошибка: " .. tostring(err) })
    end
end

function showError(message)
    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 300, 0, 30)
    notif.Position = UDim2.new(0.5, -150, 0.02, 0)
    notif.BackgroundColor3 = Color3.new(0.8, 0.2, 0.2)
    notif.TextColor3 = Color3.new(1, 1, 1)
    notif.Text = message
    notif.TextScaled = true
    notif.Font = Enum.Font.SourceSansBold
    notif.Parent = gui
    game:GetService("Debris"):AddItem(notif, 3)
end

-- ==================== ЗАПУСК ====================
connect()
showMainWindow()

-- Если персонаж ресетнулся, закрываем сессию, если не в persist (но мы не используем persist в этой версии, так что просто выходим)
player.CharacterAdded:Connect(function()
    if currentCode then
        sendToServer({ type = "leave" })
        currentCode = nil
        isCreator = false
        closeSessionWindow()
        showMainWindow()
        showError("Вы отключены (респавн)")
    end
end)
