        execBtn.Parent = sessionFrame
        execBtn.MouseButton1Click:Connect(function()
            local scriptText = scriptBox.Text
            if scriptText and #scriptText > 0 then
                sendToServer({ type = "exec", script = scriptText })
                scriptBox.Text = ""
            else
                showError("Введите скрипт")
            end
