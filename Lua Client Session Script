    outputFrame.Size = UDim2.new(1, -10, 0, 150)
    outputFrame.Position = UDim2.new(0, 5, 0, 30)
    outputFrame.BackgroundColor3 = Color3.new(0.1, 0.1, 0.1)
    outputFrame.BackgroundTransparency = 0.5
