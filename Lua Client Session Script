-- ========================================
-- Минимальный Session Sync Client
-- Только основное: код, присоединиться, создать, вывод, скрытие
-- ========================================

local player = game.Players.LocalPlayer
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

-- Переменные состояния
local ws = nil
local connected = false
local currentCode = nil
local isCreator = false

-- Функция отправки JSON
function sendToServer(data)
    if ws and connected then
        ws:Send(game:GetService("HttpService"):JSONEncode(data))
    end
end

-- Подключение к серверу
function connect()
    if ws then return true end
    local success = pcall(function()
        ws = WebSocket.connect("wss://robloxlocalscriptsync.onrender.com")
    end)
    if not success then
        pcall(function()
            ws = syn.websocket.connect("wss://robloxlocalscriptsync.onrender.com")
        end)
    end
    if not ws then
        warn("Не удалось подключиться")
        return false
    end
    connected = true
    ws.OnMessage:Connect(function(msg)
        local data = game:GetService("HttpService"):JSONDecode(msg)
        handleMessage(data)
    end)
    sendToServer({ type = "identify", name = player.Name })
    return true
end

-- Обработчик сообщений
function handleMessage(data)
    if data.type == "created" then
        currentCode = data.code
        isCreator = true
        showSessionWindow()
    elseif data.type == "joined" then
        currentCode = data.code
        isCreator = false
        showSessionWindow()
    elseif data.type == "exec" then
        executeScript(data.script)
    elseif data.type == "output" then
        addOutput(data.message)
    elseif data.type == "error" then
        showError(data.message)
    elseif data.type == "left" then
        currentCode = nil
        isCreator = false
        closeSessionWindow()
        showMainWindow()
    elseif data.type == "session_closed" then
        currentCode = nil
        isCreator = false
        closeSessionWindow()
        showMainWindow()
        showError("Сессия закрыта создателем")
    elseif data.type == "exec_sent" then
        -- не выводим ничего, просто игнорируем
    end
end

