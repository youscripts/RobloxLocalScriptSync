    sessionFrame = Instance.new("Frame")
    sessionFrame.Size = UDim2.new(0, 350, 0, 250)
    sessionFrame.Position = UDim2.new(0.5, -175, 0.3, -125)
    sessionFrame.BackgroundColor3 = Color3.new(0.15, 0.15, 0.15)
    sessionFrame.BackgroundTransparency = 0.1
    sessionFrame.Parent = gui
    makeDraggable(sessionFrame)

    -- Заголовок с кодом сессии
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 25)
    title.BackgroundTransparency = 1
    title.Text = "Сессия: " .. (currentCode or "???")
    title.TextColor3 = Color3.new(1, 1, 1)
    title.TextScaled = true
    title.Font = Enum.Font.SourceSansBold
    title.Parent = sessionFrame

    -- Кнопка закрыть (крестик)
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 25, 0, 25)
    closeBtn.Position = UDim2.new(1, -30, 0, 0)
    closeBtn.BackgroundColor3 = Color3.new(0.8, 0.2, 0.2)
    closeBtn.Text = "✕"
    closeBtn.TextColor3 = Color3.new(1, 1, 1)
    closeBtn.TextScaled = true
    closeBtn.Font = Enum.Font.SourceSansBold
    closeBtn.Parent = sessionFrame
    closeBtn.MouseButton1Click:Connect(function()
        -- Закрываем окно и выходим из сессии (или закрываем сессию, если создатель)
        if isCreator then
            sendToServer({ type = "close" })  -- закрываем сессию для всех
        else
            sendToServer({ type = "leave" })
        end
        -- Окно закроется после ответа сервера (left или session_closed)
        -- Но чтобы не ждать, сразу скроем
        sessionFrame.Visible = false
        sessionVisible = false
        showRestoreButton()
    end)

    -- Поле вывода (ScrollingFrame + TextLabel)
